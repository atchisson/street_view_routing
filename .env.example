# GraphHopper server configuration
# Copy this file to .env and modify the URL as needed
GRAPHHOPPER_URL=https://graphhopper.atchisson.fr

# Tracestrack Topo basemap (optional)
# Get a free API key at https://console.tracestrack.com
# The "Topo" basemap button only appears when a key is set.
# Note: the .env file is served to the client, so restrict the key to your domain in the Tracestrack console.
TRACESTRACK_API_KEY=